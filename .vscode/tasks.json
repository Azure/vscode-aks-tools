// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "webpack-dev",
            "type": "npm",
            "script": "webpack-dev",
            "isBackground": true,
            "problemMatcher": {
                "owner": "webpack",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "ERROR in (.+)",
                    "file": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*webpack.*compiling.*",
                    "endsPattern": "^.*webpack.*compiled.*"
                }
            }
        },
        {
            "label": "webpack",
            "type": "npm",
            "script": "webpack"
        },
        {
            "label": "test-compile",
            "type": "npm",
            "script": "test-compile"
        },
        {
            "label": "build:webview",
            "type": "npm",
            "script": "build:webview"
        },
        {
            "label": "kickstart-dev",
            "dependsOn": ["build:webview", "webpack-dev"],
            "dependsOrder": "sequence"
        },
        {
            "label": "dev:webview",
            "type": "npm",
            "script": "dev:webview",
            "problemMatcher": {
                "base": "$tsc-watch",
                "fileLocation": "absolute",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^(?:.* page reload |\\[TypeScript\\]).*",
                    "endsPattern": "^.*\\[TypeScript\\].*"
                }
            },
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            }
        }
    ]
}